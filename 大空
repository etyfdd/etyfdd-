local HBSize, HBEnabled, OldProps = 30, false, {}

local function setHitbox(char, en)
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if en then
        if not OldProps[root] then OldProps[root] = {Size = root.Size, Trans = root.Transparency, Coll = root.CanCollide} end
        root.Size = Vector3.new(HBSize, HBSize, HBSize)
        root.Transparency = 0.95
        root.CanCollide = true
